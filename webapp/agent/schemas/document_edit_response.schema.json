{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "assistant_message", "navigation_label", "suggestions"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "assistant_message": {
      "type": "string",
      "minLength": 1
    },
    "navigation_label": {
      "type": "string",
      "minLength": 1
    },
    "suggestions": {
      "type": "array",
      "items": { "$ref": "#/$defs/suggestion" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "documentBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "text"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["heading", "paragraph", "bullet_list", "ordered_list", "blockquote"]
        },
        "text": { "type": "string" },
        "attrs": { "type": "object" }
      }
    },
    "addOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "after_block_id", "block"],
      "properties": {
        "op": { "const": "add" },
        "after_block_id": {
          "type": ["string", "null"]
        },
        "block": { "$ref": "#/$defs/documentBlock" },
        "reason": { "type": "string" }
      }
    },
    "removeOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "block_id"],
      "properties": {
        "op": { "const": "remove" },
        "block_id": { "type": "string" },
        "removed_block": { "$ref": "#/$defs/documentBlock" },
        "reason": { "type": "string" }
      }
    },
    "modifyOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "block_id", "after"],
      "properties": {
        "op": { "const": "modify" },
        "block_id": { "type": "string" },
        "before": { "$ref": "#/$defs/documentBlock" },
        "after": { "$ref": "#/$defs/documentBlock" },
        "reason": { "type": "string" }
      }
    },
    "suggestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "category", "summary", "operations"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": ["title", "lede", "structure", "readability", "keyword", "tag", "risk", "body"]
        },
        "summary": { "type": "string", "minLength": 1 },
        "reason": { "type": "string" },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/addOperation" },
              { "$ref": "#/$defs/removeOperation" },
              { "$ref": "#/$defs/modifyOperation" }
            ]
          }
        }
      }
    }
  }
}
