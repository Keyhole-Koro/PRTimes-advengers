{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "tags"],
  "properties": {
    "summary": { "type": "string" },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "reason"],
        "properties": {
          "label": { "type": "string", "minLength": 2 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
