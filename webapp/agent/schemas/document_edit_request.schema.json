{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["context", "document", "instructions"],
  "properties": {
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference_docs", "uploaded_materials", "edit_history"],
      "properties": {
        "reference_docs": {
          "type": "array",
          "items": { "$ref": "#/$defs/contextDocument" }
        },
        "uploaded_materials": {
          "type": "array",
          "items": { "$ref": "#/$defs/contextDocument" }
        },
        "edit_history": {
          "type": "array",
          "items": { "$ref": "#/$defs/editHistoryEntry" }
        }
      }
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "blocks"],
      "properties": {
        "title": { "type": "string" },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/documentBlock" }
        }
      }
    },
    "instructions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goal"],
      "properties": {
        "goal": { "type": "string", "minLength": 1 },
        "tone": { "type": "string" },
        "audience": { "type": "string" },
        "style": { "type": "string" },
        "brand_voice": { "type": "string" },
        "must_include": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_avoid": {
          "type": "array",
          "items": { "type": "string" }
        },
        "language": { "type": "string" },
        "focus_points": {
          "type": "array",
          "items": { "type": "string" }
        },
        "priority_checks": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "contextDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "content"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "source_type": { "type": "string" }
      }
    },
    "editHistoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "suggestion_summary", "created_at"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["accepted", "dismissed"]
        },
        "prompt": { "type": "string" },
        "suggestion_summary": { "type": "string" },
        "suggestion_reason": { "type": "string" },
        "operation_reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "target_hint": { "type": "string" },
        "created_at": { "type": "string" }
      }
    },
    "documentBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "text"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["heading", "paragraph", "bullet_list", "ordered_list", "blockquote"]
        },
        "text": { "type": "string" },
        "attrs": { "type": "object" }
      }
    }
  }
}
